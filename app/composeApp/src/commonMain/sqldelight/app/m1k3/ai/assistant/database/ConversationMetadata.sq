-- Chat History System: ConversationMetadata Table Schema
--
-- ConversationMetadata groups messages into logical conversations for:
-- - History browsing and management
-- - Semantic search across conversations
-- - Export functionality (JSON, Markdown)
-- - Statistics and analytics
--
-- Each conversation belongs to a Project and tracks:
-- - Auto-generated or user-provided title
-- - Message/token aggregates for performance
-- - Archive flag for soft deletion
--
-- Privacy: All content encrypted at rest (SQLCipher AES-256)

CREATE TABLE IF NOT EXISTS ConversationMetadata (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    project_id TEXT NOT NULL,
    title TEXT, -- Auto-generated from first message or user-provided
    started_at INTEGER NOT NULL, -- Unix timestamp in milliseconds
    last_message_at INTEGER NOT NULL, -- Unix timestamp in milliseconds
    message_count INTEGER NOT NULL DEFAULT 0,
    token_count INTEGER NOT NULL DEFAULT 0,
    is_archived INTEGER NOT NULL DEFAULT 0, -- 0 = active, 1 = archived (soft delete)

    FOREIGN KEY (project_id) REFERENCES Project(id) ON DELETE CASCADE
);

-- Indexes for efficient conversation retrieval

-- Most important: Get conversations by project, sorted by most recent
CREATE INDEX IF NOT EXISTS idx_conversation_project_recent
ON ConversationMetadata(project_id, last_message_at DESC);

-- For filtering archived conversations
CREATE INDEX IF NOT EXISTS idx_conversation_archived
ON ConversationMetadata(is_archived, last_message_at DESC);

-- For full-text search on titles
CREATE INDEX IF NOT EXISTS idx_conversation_title
ON ConversationMetadata(title);

-- Queries

-- Insert a new conversation
insertConversation:
INSERT INTO ConversationMetadata (
    project_id,
    title,
    started_at,
    last_message_at,
    message_count,
    token_count,
    is_archived
) VALUES (?, ?, ?, ?, ?, ?, ?);

-- Get conversation by ID
getConversationById:
SELECT * FROM ConversationMetadata WHERE id = ?;

-- Get all active conversations (not archived)
getAllActiveConversations:
SELECT * FROM ConversationMetadata
WHERE is_archived = 0
ORDER BY last_message_at DESC;

-- Get active conversations for a specific project
getActiveConversationsByProject:
SELECT * FROM ConversationMetadata
WHERE project_id = ? AND is_archived = 0
ORDER BY last_message_at DESC;

-- Get archived conversations
getArchivedConversations:
SELECT * FROM ConversationMetadata
WHERE is_archived = 1
ORDER BY last_message_at DESC;

-- Update conversation metadata (after new message)
updateConversationMetadata:
UPDATE ConversationMetadata
SET
    last_message_at = ?,
    message_count = ?,
    token_count = ?
WHERE id = ?;

-- Update conversation title
updateConversationTitle:
UPDATE ConversationMetadata
SET title = ?
WHERE id = ?;

-- Archive conversation (soft delete)
archiveConversation:
UPDATE ConversationMetadata
SET is_archived = 1
WHERE id = ?;

-- Unarchive conversation
unarchiveConversation:
UPDATE ConversationMetadata
SET is_archived = 0
WHERE id = ?;

-- Delete conversation (hard delete)
deleteConversation:
DELETE FROM ConversationMetadata WHERE id = ?;

-- Get conversation count for a project
getConversationCount:
SELECT COUNT(*) FROM ConversationMetadata
WHERE project_id = ? AND is_archived = 0;

-- Get total message count across all conversations
getTotalMessageCount:
SELECT SUM(message_count) FROM ConversationMetadata
WHERE is_archived = 0;

-- Get total token count across all conversations
getTotalTokenCount:
SELECT SUM(token_count) FROM ConversationMetadata
WHERE is_archived = 0;

-- Get conversation statistics
getConversationStats:
SELECT
    COUNT(*) AS total_conversations,
    SUM(message_count) AS total_messages,
    SUM(token_count) AS total_tokens,
    AVG(CAST(message_count AS REAL)) AS avg_messages_per_conv
FROM ConversationMetadata
WHERE is_archived = 0;

-- Search conversations by title
searchConversationsByTitle:
SELECT * FROM ConversationMetadata
WHERE title LIKE '%' || ? || '%'
  AND is_archived = 0
ORDER BY last_message_at DESC
LIMIT ?;

-- Get most recent conversation for a project
getLatestConversation:
SELECT * FROM ConversationMetadata
WHERE project_id = ? AND is_archived = 0
ORDER BY last_message_at DESC
LIMIT 1;

-- Get oldest conversation (for cleanup)
getOldestConversation:
SELECT * FROM ConversationMetadata
WHERE is_archived = 0
ORDER BY started_at ASC
LIMIT 1;

-- Delete conversations older than timestamp (cleanup)
deleteOlderThan:
DELETE FROM ConversationMetadata
WHERE last_message_at < ?;
