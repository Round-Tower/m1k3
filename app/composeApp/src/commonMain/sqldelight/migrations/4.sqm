-- Migration 4 → 5: retire "zero bytes" privacy invariant.
--
-- The CHECK(bytes_sent = 0) constraint and lack of a bytes_received column
-- stem from the old "zero network" narrative. ADR-0006 retires that: the
-- app now uses the network for user-initiated model downloads and web
-- search, and we track real bytes to surface them in EcoStats.
--
-- SQLite does not support ALTER TABLE DROP CONSTRAINT, so we recreate the
-- table. Data is preserved (old rows had bytes_sent = 0 by invariant and
-- default bytes_received to 0).
--
-- MurphySig: kev+claude / confidence 0.85 / 2026-04-19

CREATE TABLE EcoMetrics_new (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    timestamp INTEGER NOT NULL,
    tokens_processed INTEGER NOT NULL,
    water_saved_ml INTEGER NOT NULL,
    energy_saved_wh INTEGER NOT NULL,
    co2_prevented_g INTEGER NOT NULL,
    bytes_sent INTEGER NOT NULL DEFAULT 0,
    bytes_received INTEGER NOT NULL DEFAULT 0,
    session_id TEXT,
    project_id TEXT,
    FOREIGN KEY (project_id) REFERENCES Project(id) ON DELETE SET NULL
);

INSERT INTO EcoMetrics_new (
    id, timestamp, tokens_processed,
    water_saved_ml, energy_saved_wh, co2_prevented_g,
    bytes_sent, bytes_received,
    session_id, project_id
)
SELECT
    id, timestamp, tokens_processed,
    water_saved_ml, energy_saved_wh, co2_prevented_g,
    bytes_sent, 0,
    session_id, project_id
FROM EcoMetrics;

DROP TABLE EcoMetrics;
ALTER TABLE EcoMetrics_new RENAME TO EcoMetrics;

CREATE INDEX IF NOT EXISTS idx_eco_timestamp
ON EcoMetrics(timestamp DESC);

CREATE INDEX IF NOT EXISTS idx_eco_session
ON EcoMetrics(session_id, timestamp ASC);

CREATE INDEX IF NOT EXISTS idx_eco_project
ON EcoMetrics(project_id, timestamp DESC);
