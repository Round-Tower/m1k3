-- Migration 5 → 6: introduce Source + Passage tables for personal-knowledge RAG.
--
-- Pivot away from the static TriviaFact corpus toward user-imported notes
-- and documents. TriviaFact stays intact for rollback; its retrieval path
-- is dormant (RAG default = false).
--
-- Day-one kinds stored in Source.kind: 'TEXT', 'MARKDOWN'. New kinds enter
-- alongside their ingestion path.
--
-- MurphySig: kev+claude / confidence 0.85 / 2026-04-19

CREATE TABLE Source (
    id TEXT NOT NULL PRIMARY KEY,
    uri TEXT NOT NULL,
    kind TEXT NOT NULL,
    title TEXT NOT NULL,
    byte_size INTEGER NOT NULL,
    chunk_count INTEGER NOT NULL,
    imported_at INTEGER NOT NULL
);

CREATE INDEX IF NOT EXISTS idx_source_imported_at
ON Source(imported_at DESC);

CREATE TABLE Passage (
    id TEXT NOT NULL PRIMARY KEY,
    source_id TEXT NOT NULL,
    sequence INTEGER NOT NULL,
    content TEXT NOT NULL,
    token_count INTEGER NOT NULL,
    total_passages_in_source INTEGER NOT NULL,
    FOREIGN KEY (source_id) REFERENCES Source(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_passage_source_seq
ON Passage(source_id, sequence ASC);
