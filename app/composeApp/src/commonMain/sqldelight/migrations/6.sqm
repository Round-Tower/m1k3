-- Migration 6 → 7: Passage embedding columns for semantic retrieval.
--
-- Adds an optional embedding BLOB + its model id to Passage rows so
-- SqlDelightPassageRepository can cosine-rank search results instead of
-- falling back to keyword LIKE. Columns are nullable — rows imported
-- before the embedding pipeline was wired stay valid; search degrades
-- gracefully to LIKE for them.
--
-- MurphySig: kev+claude / confidence 0.82 / 2026-04-19

ALTER TABLE Passage ADD COLUMN embedding BLOB;
ALTER TABLE Passage ADD COLUMN embedding_model TEXT;
