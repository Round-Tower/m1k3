<?xml version="1.0" encoding="utf-8"?>
<!--
    M1K3 AI - Android Theme
    AMOLED black, edge-to-edge first.

    Strategy:
    - Base from Theme.AppCompat.DayNight.NoActionBar — correct for Compose-first
      apps. Resolves DrawerLayout + BottomSheet at the View level.
    - All system bar colours are set to transparent here at the View level.
      Compose's enableEdgeToEdge() + SystemBarStyle handles icon tint at
      runtime, so we never fight the framework.
    - windowTranslucentStatus / windowTranslucentNavigation are intentionally
      FALSE. TranslucentDecor was the pre-API-21 workaround; it breaks
      WindowInsetsController and must not be used alongside enableEdgeToEdge().
    - windowDrawsSystemBarBackgrounds = true so the Activity window owns the
      system bar canvas (required for full transparency on API 21+).

    MurphySig: https://murphysig.dev — confident fix, API 21-36 tested pattern.
-->
<resources>

    <!-- Base application theme.
         AppCompat.DayNight.NoActionBar: correct for Compose-first apps.
         com.google.android.material is not a dependency (Compose Multiplatform
         ships its own M3 tokens). AppCompat resolves DrawerLayout correctly. -->
    <style name="Theme.M1K3" parent="Theme.AppCompat.DayNight.NoActionBar">

        <!-- Window background matches AMOLED black so pre-Compose frames
             are black rather than the default Material3 grey. -->
        <item name="android:windowBackground">@android:color/black</item>

        <!-- Transparent system bars — Compose owns the colour from here. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Required: Activity window draws the system bar backgrounds.
             Without this the OS draws its own opaque bar behind ours. -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Do NOT use translucent flags — they pre-date WindowInsetsController
             and conflict with enableEdgeToEdge(). -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>

        <!-- Enforce light (white) status bar icons for our dark background.
             enableEdgeToEdge() also sets this via WindowInsetsControllerCompat,
             but the XML value is the safe fallback for cold-start frames. -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Gesture nav bar contrast enforcement (API 29+).
             false = system will NOT force a button/scrim behind gesture nav.
             Our AMOLED background provides enough contrast on its own. -->
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>

    </style>

</resources>
