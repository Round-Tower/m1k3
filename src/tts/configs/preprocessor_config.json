{
    "processor_class": "VibeVoiceProcessor",
    "auto_map": {
        "processor": "vibevoice.processor.vibevoice_processor.VibeVoiceProcessor"
    },
    "feature_extractor_type": "VibeVoiceFeatureExtractor",
    "tokenizer_type": "VibeVoiceTextTokenizerFast",
    "speech_config": {
        "sample_rate": 24000,
        "max_length_seconds": 90,
        "normalize_audio": true,
        "return_attention_mask": true
    },
    "text_config": {
        "max_length": 512,
        "padding": true,
        "truncation": true,
        "return_tensors": "pt"
    }
}
