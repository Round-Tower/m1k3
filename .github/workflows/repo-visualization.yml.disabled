name: Repository Visualization

on:
  push:
    branches: [ main, master, develop ]
  pull_request:
    branches: [ main, master, develop ]
  schedule:
    # Generate weekly repo visualization (Sundays at 2 AM UTC)
    - cron: '0 2 * * 0'

jobs:
  visualize:
    name: 📊 Generate Repository Structure Diagram
    runs-on: ubuntu-latest
    
    permissions:
      contents: write
      pull-requests: write
      
    steps:
      - name: 📥 Checkout Code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}
      
      - name: 📊 Generate Repository Visualization
        uses: githubocto/repo-visualizer@0.9.1
        with:
          # Output configuration
          output_file: "docs/repo-structure.svg"
          output_format: "svg"
          
          # Visual styling
          root_name: "M1K3"
          max_depth: 4
          commit_sha: ${{ github.sha }}
          
          # Directory exclusions for cleaner visualization
          excluded_paths: |
            node_modules,
            .git,
            __pycache__,
            .pytest_cache,
            .coverage,
            htmlcov,
            dist,
            build,
            *.egg-info,
            .venv,
            venv,
            env,
            .env,
            VibeVoice,
            models,
            downloads,
            temp,
            tmp,
            .DS_Store,
            Thumbs.db,
            *.log,
            *.tmp,
            *.pyc,
            *.pyo,
            *.pyd,
            .tox,
            .cache,
            .mypy_cache,
            .idea,
            .vscode/settings.json,
            .vscode/launch.json,
            .github/workflows/*.yml.bak
            
          # File type exclusions
          excluded_globs: |
            **/*.pyc,
            **/*.pyo,
            **/*.pyd,
            **/*.so,
            **/*.dylib,
            **/*.dll,
            **/*.exe,
            **/*.zip,
            **/*.tar.gz,
            **/*.rar,
            **/*.7z,
            **/*.wav,
            **/*.mp3,
            **/*.mp4,
            **/*.avi,
            **/*.mov,
            **/*.jpg,
            **/*.jpeg,
            **/*.png,
            **/*.gif,
            **/*.ico,
            **/*.svg,
            **/*.pdf,
            **/*.doc,
            **/*.docx,
            **/*.xls,
            **/*.xlsx,
            **/*.ppt,
            **/*.pptx,
            **/package-lock.json,
            **/yarn.lock,
            **/Pipfile.lock,
            **/poetry.lock
      
      - name: 📁 Ensure docs directory exists
        run: |
          mkdir -p docs
          echo "📊 Repository visualization generated: $(date)" > docs/README.md
          echo "" >> docs/README.md
          echo "![M1K3 Repository Structure](repo-structure.svg)" >> docs/README.md
          echo "" >> docs/README.md
          echo "This diagram is automatically generated by the \`repo-visualization\` workflow." >> docs/README.md
          echo "Last updated: $(date -u '+%Y-%m-%d %H:%M:%S UTC')" >> docs/README.md
      
      - name: 🔍 Verify visualization output
        run: |
          if [ -f "docs/repo-structure.svg" ]; then
            echo "✅ Repository visualization generated successfully"
            echo "📏 File size: $(du -h docs/repo-structure.svg | cut -f1)"
            echo "📊 SVG contains $(grep -o '<g' docs/repo-structure.svg | wc -l) visual elements"
          else
            echo "❌ Repository visualization failed to generate"
            exit 1
          fi
      
      - name: 📈 Update visualization metadata
        run: |
          # Create metadata file with generation info
          cat > docs/repo-structure-metadata.json << EOF
          {
            "generated_at": "$(date -u -Iseconds)",
            "commit_sha": "${{ github.sha }}",
            "workflow_run": "${{ github.run_id }}",
            "trigger": "${{ github.event_name }}",
            "branch": "${{ github.ref_name }}",
            "repository": "${{ github.repository }}",
            "file_size_bytes": $(stat -f%z docs/repo-structure.svg 2>/dev/null || stat -c%s docs/repo-structure.svg),
            "svg_elements": $(grep -o '<g' docs/repo-structure.svg | wc -l)
          }
          EOF
      
      - name: 📝 Commit visualization updates
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          
          # Check if there are changes to commit
          if git diff --quiet docs/; then
            echo "📋 No changes to repository visualization"
          else
            git add docs/
            git commit -m "📊 Update repository structure visualization
            
            - Generated from commit ${{ github.sha }}
            - Triggered by: ${{ github.event_name }}
            - Updated: $(date -u '+%Y-%m-%d %H:%M:%S UTC')
            
            🤖 Generated with [Claude Code](https://claude.ai/code)
            
            Co-Authored-By: Claude <noreply@anthropic.com>"
            
            # Push only if not in a PR (avoid conflicts)
            if [ "${{ github.event_name }}" != "pull_request" ]; then
              git push
              echo "✅ Repository visualization committed and pushed"
            else
              echo "📋 Repository visualization generated (PR mode - no push)"
            fi
          fi
      
      - name: 💬 Comment on PR with visualization
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            
            // Check if visualization was generated
            if (fs.existsSync('docs/repo-structure.svg')) {
              const metadata = JSON.parse(fs.readFileSync('docs/repo-structure-metadata.json', 'utf8'));
              
              const comment = `## 📊 Repository Structure Visualization Updated
              
              This PR includes changes that affect the repository structure. A new visualization has been generated:
              
              **📈 Visualization Details:**
              - **Generated at:** ${metadata.generated_at}
              - **File size:** ${Math.round(metadata.file_size_bytes / 1024)} KB
              - **Visual elements:** ${metadata.svg_elements}
              - **Commit:** \`${metadata.commit_sha.substring(0, 7)}\`
              
              The updated repository structure diagram will be available in the \`docs/\` directory once this PR is merged.
              
              🔗 **View in GitHub Pages:** [Repository Structure](https://github.com/${{ github.repository }}/blob/${{ github.head_ref || github.ref_name }}/docs/repo-structure.svg)
              
              ---
              🤖 *Generated automatically by the Repository Visualization workflow*`;
              
              github.rest.issues.createComment({
                issue_number: context.issue.number,
                owner: context.repo.owner,
                repo: context.repo.repo,
                body: comment
              });
            }
      
      - name: 📊 Generate workflow summary
        run: |
          echo "## 📊 Repository Visualization Summary" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          
          if [ -f "docs/repo-structure.svg" ]; then
            echo "✅ **Status:** Successfully generated repository structure diagram" >> $GITHUB_STEP_SUMMARY
            echo "📏 **File size:** $(du -h docs/repo-structure.svg | cut -f1)" >> $GITHUB_STEP_SUMMARY
            echo "📊 **Visual elements:** $(grep -o '<g' docs/repo-structure.svg | wc -l)" >> $GITHUB_STEP_SUMMARY
            echo "🕒 **Generated at:** $(date -u '+%Y-%m-%d %H:%M:%S UTC')" >> $GITHUB_STEP_SUMMARY
            echo "" >> $GITHUB_STEP_SUMMARY
            echo "📁 **Output location:** \`docs/repo-structure.svg\`" >> $GITHUB_STEP_SUMMARY
            echo "📋 **Metadata:** \`docs/repo-structure-metadata.json\`" >> $GITHUB_STEP_SUMMARY
          else
            echo "❌ **Status:** Failed to generate repository visualization" >> $GITHUB_STEP_SUMMARY
          fi