      "type": "image/png",
      "form_factor": "narrow",
      "label": "M1K3 mobile chat interface"
    },
    {
      "src": "icons/screenshot-desktop.png", 
      "sizes": "1200x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "M1K3 desktop interface"
    }
  ],
  "shortcuts": [
    {
      "name": "New Chat",
      "short_name": "Chat",
      "description": "Start a new conversation with M1K3",
