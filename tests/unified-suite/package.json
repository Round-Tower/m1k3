{
  "name": "m1k3-unified-test-suite",
  "version": "1.0.0",
  "description": "M1K3 Unified Test Suite with Security Auditing and Brand-Aligned Reporting",
  "main": "unified-test-runner.js",
  "bin": {
    "m1k3-test": "./unified-test-runner.js",
    "m1k3-discover": "./test-discovery.js",
    "m1k3-report": "./report-generator.js",
    "m1k3-tdd": "./tdd-helper.js"
  },
  "scripts": {
    "test": "node unified-test-runner.js",
    "test:quick": "node unified-test-runner.js --quick",
    "test:unit": "node unified-test-runner.js --categories unit",
    "test:integration": "node unified-test-runner.js --categories integration", 
    "test:visual": "node unified-test-runner.js --categories visual",
    "test:security": "node unified-test-runner.js --categories security",
    "test:performance": "node unified-test-runner.js --categories performance",
    "test:e2e": "node unified-test-runner.js --categories e2e",
    "test:api": "node unified-test-runner.js --categories api",
    "test:unified": "node unified-test-runner.js --all --report",
    "test:watch": "node tdd-helper.js watch",
    "test:ci": "node unified-test-runner.js --ci",
    "tdd": "node tdd-helper.js",
    "tdd:init": "node tdd-helper.js init",
    "tdd:cycle": "node tdd-helper.js cycle",
    "tdd:watch": "node tdd-helper.js watch",
    "tdd:quick": "node tdd-helper.js quick",
    "audit": "node security-auditor.js",
    "audit:security": "node security-auditor.js",
    "report": "node report-generator.js",
    "report:generate": "node report-generator.js --standalone",
    "export": "node data-exporter.js",
    "export:json": "node data-exporter.js --format=json",
    "export:csv": "node data-exporter.js --format=csv",
    "export:xml": "node data-exporter.js --format=xml",
    "export:yaml": "node data-exporter.js --format=yaml",
    "discover": "node test-discovery.js",
    "discover:scan": "node test-discovery.js --scan",
    "install-deps": "npm install && pip install -r requirements.txt",
    "setup": "npm run install-deps && mkdir -p output/data output/reports output/exports && echo 'M1K3 Unified Test Suite setup complete'"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "node-fetch": "^3.3.2",
    "chokidar": "^3.5.3",
    "glob": "^10.3.10",
    "chalk": "^5.3.0",
    "semver": "^7.5.4",
    "js-yaml": "^4.1.0",
    "commander": "^11.1.0",
    "lighthouse": "^11.4.0",
    "retire": "^4.0.3",
    "eslint": "^8.57.0",
    "jsdoc": "^4.0.2",
    "csv-writer": "^1.6.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "@playwright/test": "^1.40.0",
    "nyc": "^15.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "testing",
    "security",
    "tdd",
    "visual-regression",
    "m1k3",
    "unified-testing",
    "ai",
    "automation",
    "performance",
    "reporting"
  ],
  "author": "M1K3 Team",
  "license": "MIT"
}