{
  "m1k3_unified_test_suite": {
    "version": "1.0.0",
    "name": "M1K3 Unified Test Suite",
    "description": "Comprehensive testing system for M1K3 AI assistant project",
    
    "test_discovery": {
      "root_directory": "../..",
      "patterns": {
        "javascript": ["**/test*.js", "**/*.test.js", "**/*.spec.js"],
        "python": ["**/test_*.py", "**/*_test.py"],
        "html": ["**/test*.html", "**/*test*.html"],
        "config": ["**/playwright.config.js", "**/jest.config.js", "**/pytest.ini"]
      },
      "ignore_patterns": [
        "**/node_modules/**",
        "**/venv/**",
        "**/.git/**",
        "**/coverage/**",
        "**/output/**",
        "**/.pytest_cache/**",
        "**/dist/**",
        "**/build/**"
      ]
    },
    
    "test_categories": {
      "unit": {
        "description": "Individual component tests",
        "timeout": 5000,
        "priority": 1,
        "tags": ["fast", "isolated"]
      },
      "integration": {
        "description": "Component interaction tests",
        "timeout": 15000,
        "priority": 2,
        "tags": ["medium", "connected"]
      },
      "visual": {
        "description": "Screenshot and visual regression tests",
        "timeout": 30000,
        "priority": 3,
        "tags": ["slow", "visual"]
      },
      "performance": {
        "description": "Performance and benchmark tests",
        "timeout": 60000,
        "priority": 3,
        "tags": ["slow", "performance"]
      },
      "security": {
        "description": "Security vulnerability tests",
        "timeout": 45000,
        "priority": 2,
        "tags": ["medium", "security"]
      },
      "e2e": {
        "description": "End-to-end user journey tests",
        "timeout": 120000,
        "priority": 4,
        "tags": ["slow", "journey"]
      },
      "api": {
        "description": "API endpoint and WebSocket tests",
        "timeout": 10000,
        "priority": 2,
        "tags": ["medium", "network"]
      }
    },
    
    "frameworks": {
      "javascript": {
        "jest": {
          "command": "npx jest",
          "config_file": "jest.config.js",
          "output_format": "json"
        },
        "playwright": {
          "command": "npx playwright test",
          "config_file": "playwright.config.js",
          "output_format": "json"
        },
        "mocha": {
          "command": "npx mocha",
          "config_file": ".mocharc.json",
          "output_format": "json"
        }
      },
      "python": {
        "pytest": {
          "command": "python -m pytest",
          "config_file": "pytest.ini",
          "output_format": "json"
        },
        "unittest": {
          "command": "python -m unittest",
          "config_file": null,
          "output_format": "text"
        }
      },
      "html": {
        "qunit": {
          "command": "node qunit-runner.js",
          "config_file": null,
          "output_format": "json"
        }
      }
    },
    
    "reporting": {
      "formats": ["html", "json", "csv", "xml", "yaml"],
      "output_directory": "./output",
      "template_directory": "./templates",
      "assets_directory": "./assets",
      "brand": {
        "name": "M1K3",
        "colors": {
          "primary": "#000000",
          "accent": "#E25303",
          "success": "#10b981",
          "error": "#ef4444",
          "warning": "#f59e0b",
          "info": "#3b82f6"
        },
        "fonts": {
          "primary": "system-ui, -apple-system, sans-serif",
          "mono": "ui-monospace, 'SF Mono', Consolas, monospace"
        }
      }
    },
    
    "security_audit": {
      "enabled": true,
      "scans": {
        "dependency_vulnerabilities": true,
        "code_analysis": true,
        "secrets_scanning": true,
        "file_permissions": true,
        "network_security": true,
        "privacy_compliance": true
      },
      "severity_levels": ["low", "medium", "high", "critical"],
      "fail_on_severity": "high"
    },
    
    "tdd_workflow": {
      "watch_mode": {
        "enabled": true,
        "file_patterns": ["**/*.js", "**/*.py", "**/*.html", "**/*.css"],
        "quick_test_timeout": 30000,
        "quick_test_categories": ["unit"],
        "quick_test_tags": ["fast", "critical"]
      },
      "cycle_phases": {
        "red": {
          "description": "Write failing tests",
          "expect_failures": true
        },
        "green": {
          "description": "Write minimal implementation",
          "expect_success": true
        },
        "refactor": {
          "description": "Improve code quality",
          "run_full_suite": true
        }
      },
      "coverage_targets": {
        "statements": 80,
        "branches": 70,
        "functions": 85,
        "lines": 80
      }
    },
    
    "execution": {
      "parallel": {
        "enabled": true,
        "max_workers": 4,
        "categories_parallel": ["unit", "integration", "api"],
        "categories_sequential": ["visual", "e2e", "performance"]
      },
      "retries": {
        "enabled": true,
        "max_attempts": 3,
        "retry_delay": 1000,
        "categories_retry": ["visual", "e2e", "performance"]
      },
      "timeouts": {
        "global": 600000,
        "per_category": {
          "unit": 30000,
          "integration": 60000,
          "visual": 120000,
          "performance": 180000,
          "security": 120000,
          "e2e": 300000,
          "api": 60000
        }
      }
    },
    
    "notification": {
      "enabled": false,
      "on_completion": true,
      "on_failure": true,
      "methods": {
        "console": {
          "enabled": true,
          "colors": true,
          "verbose": false
        },
        "file": {
          "enabled": true,
          "path": "./output/notifications.log"
        }
      }
    },
    
    "integration": {
      "ci_cd": {
        "github_actions": {
          "workflow_file": ".github/workflows/test.yml",
          "trigger_events": ["push", "pull_request"]
        },
        "gitlab_ci": {
          "config_file": ".gitlab-ci.yml"
        }
      },
      "code_coverage": {
        "tools": ["nyc", "coverage.py"],
        "output_formats": ["lcov", "html", "json"]
      },
      "quality_gates": {
        "min_coverage": 75,
        "max_failures": 5,
        "max_duration": 600000
      }
    }
  }
}