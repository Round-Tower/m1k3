<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox: privacy-by-default, matches the M1K3 ethos. The store and
	     all data live in the app container; documents enter only via explicit
	     user selection / drop. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Read PDFs / text the user explicitly drops or opens. -->
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<!-- Outbound network — the ONLY reason the app reaches the internet: downloading
	     on-device model weights (MLX brains + WhisperKit) from huggingface.co on
	     first use. Without this the sandbox blocks DNS itself (NSURLError -1003,
	     "hostname could not be found") and Lil/Big can't be fetched. Chat, RAG,
	     documents, and calls stay fully on-device; nothing is uploaded. Matches the
	     onboarding promise: "Downloads … only when you ask."
	     Signed: Kev + claude-opus-4-8, 2026-06-08, Confidence 0.85, Prior: Unknown -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Inbound LISTENING for the in-process MCP server only — bound to
	     127.0.0.1 explicitly (LocalMCPHTTPServer pins requiredLocalEndpoint to
	     loopback), default OFF in Settings. Lets a local Claude session use
	     M1K3's knowledge/voice tools; nothing is ever reachable from the LAN.
	     Signed: Kev + claude-fable-5, 2026-06-11, Confidence 0.85, Prior: Unknown -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Microphone access for voice input (Apple Speech / WhisperKit). On-device
	     recognition only — audio never leaves this Mac. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- AVSpeechSynthesizer (P6/P8 voice) reaches the audioanalyticsd mach service
	     during TTS setup. Under the sandbox this throws a hard PRECONDITION
	     FAILURE ("…doesn't contain 'com.apple.audioanalyticsd'") and kills audio
	     output (CoreAudio -10877). The EffectfulSpeechProvider path
	     (AVSpeechSynthesizer.write → AVAudioEngine) checks the NON-temporary
	     `…exception.mach-lookup.global-name` key by name, so BOTH variants are
	     listed: the temporary one satisfied plain .speak; the non-temporary one is
	     what the engine/write path's precondition actually reads. Scoped to the one
	     analytics service the synthesizer needs — no broader hole.
	     Signed: Kev + claude-sonnet-4-6, 2026-06-08, Confidence 0.6, Prior: Kev + claude-opus-4-8 -->
	<key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
	<array>
		<string>com.apple.audioanalyticsd</string>
	</array>
	<key>com.apple.security.exception.mach-lookup.global-name</key>
	<array>
		<string>com.apple.audioanalyticsd</string>
	</array>
</dict>
</plist>
