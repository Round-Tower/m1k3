<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Mac App Store entitlements. Identical to M1K3.entitlements MINUS the two
	     audioanalyticsd mach-lookup exceptions, which the App Store rejects
	     (temporary-exception.* and private-service exception.mach-lookup are
	     disallowed). Those exist only for the AVSpeechSynthesizer system-voice
	     path; the Kokoro neural voice (on-device ONNX, no mach service) needs
	     none of them. See macos/tools/release/README.md §2. -->

	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<!-- Outbound: on-device model-weight downloads (HuggingFace) on first use. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Inbound loopback only: the in-process MCP server (default OFF). -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Microphone for on-device voice input (Apple Speech / WhisperKit). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
