# Swift Package Manager
.build/
# xcodebuild -clonedSourcePackagesDirPath cache (local build artifact).
.spm-cache/
.swiftpm/
# NOTE: Package.resolved IS committed (not ignored). Xcode Cloud disables
# automatic package resolution and requires a committed lockfile; ci_post_clone.sh
# seeds it into the generated .xcodeproj workspace. Keep it current: run
# `swift package resolve` and commit when dependencies change.

# Xcode (app shell added at the UI phase)
DerivedData/
*.xcuserstate
xcuserdata/

# XcodeGen artifacts — project.yml is the source of truth; regenerate the
# project + generated plist with `xcodegen generate`.
M1K3.xcodeproj/
M1K3App/Info.generated.plist
M1K3iOSApp/Info.generated.plist

# macOS
.DS_Store

# Track the shared package test scheme (M1K3-Tests) so Xcode Cloud enumerates it
# as a package scheme. .swiftpm is otherwise ignored; un-ignore just this path
# (git needs each parent dir un-ignored to reach the file).
!.swiftpm/
.swiftpm/*
!.swiftpm/xcode/
.swiftpm/xcode/*
!.swiftpm/xcode/xcshareddata/
.swiftpm/xcode/xcshareddata/*
!.swiftpm/xcode/xcshareddata/xcschemes/
